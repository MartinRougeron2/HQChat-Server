# Copy to server/messages/.env on the VPS and fill in. Never commit the real file.

# --- Server identity --------------------------------------------------------
# Shown at /info so clients can validate the URL before connecting.
SERVER_NAME=DissQus
# Public origin used for Stripe redirect URLs and links (no trailing slash).
PUBLIC_BASE_URL=https://chat.example.com

# Server
PORT=8080

# --- Admission policy -------------------------------------------------------
# Who may use this server once authenticated (HQC challenge always applies):
#   open      — anyone (default; recommended for self-hosting)
#   allowlist — only the public keys in ADMISSION_ALLOWLIST
#   stripe    — requires an active Stripe subscription (the official server)
ADMISSION_POLICY=open
# Comma-separated hex public keys, used when ADMISSION_POLICY=allowlist.
ADMISSION_ALLOWLIST=
# Public keys that always bypass the admission policy (e.g. the helper bot).
EXEMPT_PUBLIC_KEYS=

# --- Helper bot (optional) --------------------------------------------------
BOT_USERNAME=helper
# Fixed 32-byte hex seed so the bot's identity is stable across redeploys.
# (If unset, the bot generates one in bot/.bot-seed on first run.)
BOT_SEED=

# --- Redis ------------------------------------------------------------------
# Include the password set via requirepass in redis.conf.
REDIS_URL=redis://:CHANGE_ME@127.0.0.1:6379

# --- Stripe (only needed when ADMISSION_POLICY=stripe) ----------------------
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx        # from the Stripe webhook endpoint you create

# --- APNs push (optional — leave blank to disable push entirely) ------------
# From Apple Developer → Keys (create an APNs Auth Key, download the .p8).
APNS_KEY_ID=ABC123DEF4
APNS_TEAM_ID=YOUR_TEAM_ID
# Paste the .p8 contents on one line with literal \n between lines:
APNS_KEY_P8="-----BEGIN PRIVATE KEY-----\nMIG...\n-----END PRIVATE KEY-----"
APNS_TOPIC_IOS=martin.rougeron.DissQus-iOS      # iOS app bundle id
APNS_TOPIC_MACOS=martin.rougeron.DissQus        # macOS app bundle id
APNS_ENV=sandbox                                 # sandbox for dev/TestFlight, production for App Store
